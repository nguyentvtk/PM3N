# ============================================================
# .env.local — Congvan_Kyso WebApp
# ============================================================
# KHÔNG commit file .env.local thật lên Git!
# Sao chép file này thành .env.local và điền giá trị thực.
# ============================================================

# ---- Google OAuth2 (NextAuth) ----
# Lấy từ: console.cloud.google.com > Credentials > OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ---- Google Service Account (đọc/ghi Sheets) ----
# Tạo: console.cloud.google.com > IAM > Service Accounts > Keys > JSON
# Share Spreadsheet với email service account này!
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ---- Google Spreadsheet ----
# Lấy sau khi chạy GAS setupSheets()
GOOGLE_SPREADSHEET_ID=your-google-spreadsheet-id

# ---- NextAuth ----
# Tạo bằng: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-random-32-chars
NEXTAUTH_URL=https://your-app.vercel.app

# ---- Google Drive ----
# ID thư mục tổng lưu công văn hoàn thiện
# Lấy từ URL: https://drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-google-drive-root-folder-id

# ---- Google Apps Script Web App (optional) ----
# Sau khi deploy GAS, dùng URL này làm fallback API
GAS_WEB_APP_URL=https://script.google.com/macros/s/your-gas-script-id/exec

# ---- Telegram Notification Bot ----
# Cấu hình bot và chat ID để nhận thông báo tự động
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ============================================================
# ---- Nodemailer SMTP — Quên mật khẩu ----
# Gmail: Tạo App Password tại https://myaccount.google.com/apppasswords
# (Yêu cầu bật 2FA trên tài khoản Gmail trước)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_FROM="PM3N Công Văn <noreply@pm3n.com>"

# ---- JWT Secret riêng cho Reset Password Token ----
# Tạo bằng: openssl rand -base64 32
RESET_PASSWORD_SECRET=your-reset-password-secret-random-32-chars
